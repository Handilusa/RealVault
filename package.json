{
  "name": "realvault",
  "version": "1.0.0",
  "description": "RealVault - Confidential RWA Fund Router built on iExec Nox Protocol",
  "main": "index.js",
  "scripts": {
    "build": "cd frontend && npm run build",
    "vercel-build": "cd frontend && npm run build",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:arbitrum": "hardhat run scripts/deploy.js --network arbitrumSepolia",
    "check:nav": "hardhat run scripts/nav-integrity-check.js --network sepolia",
    "simulate:sepolia": "hardhat run scripts/simulate-sepolia-flow.js --network sepolia",
    "simulate:arbitrum": "hardhat run scripts/simulate-sepolia-flow.js --network arbitrumSepolia",
    "benchmark:gas": "hardhat run scripts/gas-scaling-benchmark.js --network sepolia"
  },
  "keywords": [
    "hardhat",
    "iexec",
    "nox",
    "fhe",
    "confidential-contracts",
    "rwa",
    "erc7984"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.17.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@iexec-nox/handle": "^0.1.0-beta.13",
    "@iexec-nox/nox-confidential-contracts": "^0.2.2",
    "@iexec-nox/nox-protocol-contracts": "^0.2.4",
